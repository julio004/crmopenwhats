# --- SOLO PARA DESARROLLO (MODO PRUEBA DE SEGUIMIENTOS) ---
# Frecuencia con la que el scheduler busca candidatos de seguimiento (ej: 5000 = 5s, 60000 = 1m)
# DEV_FOLLOWUP_POLL_INTERVAL_MS=5000
# Antigüedad mínima del último mensaje de la IA para enviar seguimiento (ej: 5 = 5s, 3600 = 1 hora)
# DEV_FOLLOWUP_MIN_AGE_SECONDS=5
